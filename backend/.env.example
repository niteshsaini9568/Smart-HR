# Server
NODE_ENV=development
PORT=5000

# Public URLs (required in production)
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/hrms

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
SESSION_SECRET=change-me-to-another-long-random-string

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hrms/resumes

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/v1/auth/linkedin/callback

# AI / ML (optional)
HUGGINGFACE_API_KEY=
HF_ACCESS_TOKEN=
HF_TTS_MODEL=microsoft/speecht5_tts
HF_WHISPER_MODEL=openai/whisper-large-v3

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Upload limits
MAX_FILE_SIZE=5242880

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
